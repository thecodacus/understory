{
  "name": "@understory/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ustory": "./bin/ustory"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mcp:stdio": "tsx src/mcp/stdio.ts",
    "test": "pnpm run typecheck:test && vitest run --passWithNoTests",
    "typecheck:test": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@understory/core": "workspace:*",
    "ai": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
